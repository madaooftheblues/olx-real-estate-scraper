# ─────────────────────────────────────────────────────────────────────────────
# OLX Scraper API — Environment Variables
# Copy to .env for local dev. Set in Coolify dashboard for production.
# ─────────────────────────────────────────────────────────────────────────────

# REQUIRED
OLX_API_KEY=your-secret-key-here

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8000
DEBUG=false
GUNICORN_TIMEOUT=120

# ── Scraper ───────────────────────────────────────────────────────────────────
PAGE_TIMEOUT_MS=30000
DELAY_MIN=1.5
DELAY_MAX=4.0
SCROLL_STEPS=3
HEADLESS=true
MAX_PAGES=0

# ── Stealth ───────────────────────────────────────────────────────────────────
# Cookie file path — must be on a persistent volume in production
# Coolify: mount a volume at /data, set this to /data/cookies.json
# Local dev: any writable path e.g. ./cookies.json
COOKIE_FILE=/data/cookies.json

# OLX homepage visited before search URLs (warm-up)
WARMUP_URL=https://www.olx.pl

# ── Reference ID ──────────────────────────────────────────────────────────────
REF_PREFIX=OLX
REF_PADDING=4
