# ─────────────────────────────────────────────────────────────────────────────
# OLX Scraper API — Environment Variables
# Copy this to .env for local dev. Set these in Coolify dashboard for production.
# ─────────────────────────────────────────────────────────────────────────────

# REQUIRED — generate with: python -c "import secrets; print(secrets.token_hex(32))"
OLX_API_KEY=your-secret-key-here

# ── Server ────────────────────────────────────────────────────────────────────
# Coolify injects PORT automatically — only set manually for local dev
PORT=8000
DEBUG=false

# ── Gunicorn ──────────────────────────────────────────────────────────────────
# Increase if scrapes time out (value in seconds)
GUNICORN_TIMEOUT=120

# ── Scraper behaviour ─────────────────────────────────────────────────────────
PAGE_TIMEOUT_MS=30000
DELAY_MIN=1.2
DELAY_MAX=3.5
SCROLL_STEPS=6
HEADLESS=true

# Max pages per URL — 0 means unlimited, set e.g. 3 to cap pagination
MAX_PAGES=0

# ── Reference ID format ───────────────────────────────────────────────────────
REF_PREFIX=OLX
REF_PADDING=4
